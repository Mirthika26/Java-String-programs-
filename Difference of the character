import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner sc = new Scanner(System.in);
       String str = sc.nextLine();
       int count1 = 0;
       int count2 = 0;
       for(int i =0;i<str.length();i++){
        if(str.charAt(i) == '#'){
            count1++;
        }
        else{
            count2++;
        }
       }
       if(count1 > count2){
        count1 = count1-count2;
        if(count1%2 == 0){
            System.out.print("The Difference of the character in the given string: 0"+count1);
        }
        else{
        System.out.print("The Difference of the character in the given string: 00"+count1);
        }
       }
       else if(count1 == count2){
        System.out.print("number of * and # are equal");
       }
       else{
        count2 = count2-count1;
        if(count2%2 == 0){
            System.out.print("The Difference of the character in the given string: 0"+count2);
        }
        else{
        System.out.print("The Difference of the character in the given string: 00"+count2);
        }
       }
    }
}
